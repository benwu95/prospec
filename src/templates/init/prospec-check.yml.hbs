# Prospec deterministic drift gate — zero LLM, zero tokens.
# Supply-chain hardening is the default here:
#   - every third-party action is pinned to a full commit SHA (tag re-point immunity)
#   - top-level permissions are read-only; only the comment job may write PR comments
#   - the comment job never checks out source — it only sees the report artifact
name: Prospec Check

on:
  push:
    branches:
      - main
  pull_request:

permissions:
  contents: read

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10 # v6.0.3
        with:
          # Full history — the knowledge-health check compares git commit timestamps;
          # a shallow clone would honestly degrade it to `skipped`.
          fetch-depth: 0
{{#if use_pnpm}}
      - uses: pnpm/action-setup@0e279bb959325dab635dd2c09392533439d90093 # v6.0.8
{{/if}}
      - uses: actions/setup-node@48b55a011bda9f5d6aeb4c2d9c7362e8dae4041e # v6.4.0
        with:
          node-version: 22
{{#if use_pnpm}}
          cache: pnpm
{{/if}}
      - run: {{install_cmd}}
      - name: Run prospec check (strict gate)
        # explicit bash turns on pipefail — without it, tee's exit 0 would mask the gate
        shell: bash
        run: {{check_cmd}} | tee prospec-check-output.txt
      - name: Upload drift report
        if: always()
        uses: actions/upload-artifact@043fb46d1a93c77aae656e7c1c64a875d1fc6a0a # v7.0.1
        with:
          name: prospec-report
          path: |
            prospec-report.json
            prospec-check-output.txt
          if-no-files-found: ignore

  comment:
    if: always() && github.event_name == 'pull_request'
    needs: check
    runs-on: ubuntu-latest
    permissions:
      pull-requests: write
    steps:
      - name: Download drift report
        continue-on-error: true
        uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1
        with:
          name: prospec-report
      - name: Compose comment body
        # output is attacker-influenced on PRs — render as a 4-space indented code
        # block (no fence to escape) and cap the size; never as raw markdown
        run: |
          {
            echo '## Prospec Check'
            echo
            if [ -f prospec-check-output.txt ]; then
              head -c 60000 prospec-check-output.txt | sed 's/^/    /'
            else
              echo '_check job produced no output (it may have failed before running prospec check)_'
            fi
          } > comment-body.md
      - name: Post sticky PR comment
        uses: marocchino/sticky-pull-request-comment@0ea0beb66eb9baf113663a64ec522f60e49231c0 # v3.0.4
        with:
          path: comment-body.md
